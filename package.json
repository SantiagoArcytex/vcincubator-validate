{
  "name": "@vcincubator/validate",
  "version": "0.1.0",
  "description": "Validate VCI Marketplace license codes from your app. Tiny, zero-dependency wrapper around the VCI validation API with retries, caching, and TypeScript types.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vci-validate": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "skill",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "vci",
    "vcinc",
    "marketplace",
    "license",
    "license-validation",
    "redemption-code",
    "saas",
    "monetization"
  ],
  "author": "VCI Marketplace",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SantiagoArcytex/vcincubator-validate.git"
  },
  "bugs": {
    "url": "https://github.com/SantiagoArcytex/vcincubator-validate/issues"
  },
  "homepage": "https://marketplace.vcinc.ai",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
